# ==================== VERSION ====================
show_version() {
    echo "🌙 NYX-ROUTER v2.2.0"
    echo "   47+ Models, 44 Free Models, 14 Providers"
    echo "   MIT License"
    echo "   https://github.com/yourusername/nyx-router"
}

# ==================== UI ====================
start_ui() {
    echo "🌙 Starting NYX-ROUTER Web UI..."
    echo "   Open http://localhost:7860"
    echo ""
    python3 "$NYX_ROOT/web-ui.py"
}

# ==================== MAIN ====================
main() {
    local mode=""
    local ai=""
    local max_iter=3
    local prompt=""
    local free_flag=""
    local show_logo_flag=true

    if [ "$1" = "ui" ]; then
        start_ui
        exit 0
    fi

    while [[ $# -gt 0 ]]; do
        case $1 in
            1|single)    mode="single"; shift ;;
            2|swarm)     mode="swarm"; shift ;;
            3|orch)      mode="orch"; shift ;;
            --ai)        ai="$2"; shift 2 ;;
            --max)       max_iter="$2"; shift 2 ;;
            --free)      free_flag="--free"; shift ;;
            --no-logo)   show_logo_flag=false; shift ;;
            -h|--help)   show_help; exit 0 ;;
            -v|--version) show_version; exit 0 ;;
            ui)          start_ui; exit 0 ;;
            *)           prompt="$prompt $1"; shift ;;
        esac
    done

    prompt=$(echo "$prompt" | xargs)

    if [ -z "$mode" ] || [ -z "$prompt" ]; then
        show_help
        exit 1
    fi

    if [ "$show_logo_flag" = true ]; then
        show_logo
        echo ""
    fi

    case "$mode" in
        single|orch)
            python3 "$NYX_ROOT/core.py" "$mode" --ai "$ai" --max "$max_iter" $free_flag "$prompt"
            ;;
        swarm)
            if command -v node &> /dev/null; then
                node "$NYX_ROOT/swarm.js" "$prompt" $free_flag
            else
                echo "❌ Node.js not found. Install with: sudo apt install nodejs"
                exit 1
            fi
            ;;
        *)
            echo "❌ Mode '$mode' tidak dikenal"
            exit 1
            ;;
    esac
}

export NYX_ROOT="${NYX_ROOT:-$HOME/.nyx-router}"
export PATH="$NYX_ROOT/bin:$PATH"

if ! command -v python3 &> /dev/null; then
    echo "❌ Python3 not found. Please install Python3."
    exit 1
fi

main "$@"
