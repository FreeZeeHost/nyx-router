#!/bin/bash
NYX_ROOT="${NYX_ROOT:-$HOME/.nyx-router}"

main() {
    if [ "$1" = "ui" ]; then
        echo "🌙 Starting UI at http://localhost:7860"
        python3 "$NYX_ROOT/web_ui.py"
        exit 0
    fi
    python3 "$NYX_ROOT/core.py" "$@"
}

export NYX_ROOT="${NYX_ROOT:-$HOME/.nyx-router}"
main "$@"
